# ── ManuFoundry Backend Environment ──────────────────────
# Copy to .env and adjust for your environment.

# App
APP_MODE=demo
DEBUG=true
LOG_LEVEL=INFO

# Auth — set DEMO_AUTH_OPTIONAL=false in production to enforce 401 on protected routes
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480
DEMO_AUTH_OPTIONAL=true

# CORS (comma-separated; use explicit origins in production)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=manufoundry
POSTGRES_PASSWORD=manufoundry123
POSTGRES_DB=manufoundry

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=manufoundry123

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# OpenAI (optional — for AI assistant)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
